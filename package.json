{
  "name": "@silesiansolutions/search-quality-kit",
  "version": "0.2.0",
  "description": "Framework-agnostic CLI for auditing technical Google Search foundations in local builds and CI.",
  "type": "module",
  "bin": {
    "search-quality-kit": "dist/cli/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli/index.ts",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run build",
    "check": "npm run typecheck && npm run lint && npm test && npm run build"
  },
  "engines": {
    "node": ">=20.11"
  },
  "keywords": [
    "seo",
    "google-search",
    "technical-seo",
    "crawler",
    "cli",
    "quality"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/silesiansolutions/search-quality-kit.git"
  },
  "bugs": {
    "url": "https://github.com/silesiansolutions/search-quality-kit/issues"
  },
  "homepage": "https://www.npmjs.com/package/@silesiansolutions/search-quality-kit",
  "publishConfig": {
    "access": "public"
  },
  "overrides": {
    "esbuild": "0.28.1"
  },
  "dependencies": {
    "cheerio": "^1.1.0",
    "commander": "^14.0.0",
    "fast-xml-parser": "^5.2.5",
    "jiti": "^2.4.2",
    "picocolors": "^1.1.1",
    "zod": "^4.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/node": "^22.15.34",
    "eslint": "^9.30.1",
    "prettier": "^3.6.2",
    "tsx": "^4.20.3",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1",
    "vitest": "^3.2.4"
  }
}
