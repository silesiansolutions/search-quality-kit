{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "baseUrl": ".",
    "paths": {
      "@silesiansolutions/search-quality-kit": ["./src/index.ts"],
      "@silesiansolutions/search-quality-kit/test-utils": [
        "./src/test-utils.ts"
      ]
    },
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "noUncheckedIndexedAccess": true,
    "rootDir": ".",
    "outDir": "dist"
  },
  "include": ["src", "tests", "examples/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
